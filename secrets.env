# Lokal secrets-fil for ingve.com
# Verdier hentes automatisk fra GitHub Codespaces Secrets når du åpner Codespace.
# Fyll inn manuelt kun ved lokal kjøring utenfor Codespace.

INGVE_SITE_URL=${INGVE_SITE_URL:-https://ingve.com}
INGVE_LOGIN_USERNAME=${INGVE_LOGIN_USERNAME:-}
INGVE_LOGIN_PASSWORD=${INGVE_LOGIN_PASSWORD:-}

# FTP
INGVE_FTP_HOST=${INGVE_FTP_HOST:-ftp.ingve.com}
INGVE_FTP_USERNAME=${INGVE_FTP_USERNAME:-ingve.com}
INGVE_FTP_PORT=${INGVE_FTP_PORT:-21}
