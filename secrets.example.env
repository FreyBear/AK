# Eksempelmal for ingve.com secrets.
# Legg ekte verdier i secrets.env lokalt eller i GitHub Codespaces Secrets.

INGVE_SITE_URL=https://ingve.com
INGVE_LOGIN_USERNAME=
INGVE_LOGIN_PASSWORD=

# FTP
INGVE_FTP_HOST=ftp.ingve.com
INGVE_FTP_USERNAME=ingve.com
INGVE_FTP_PORT=21
INGVE_FTP_PASSWORD=
INGVE_FTP_REMOTE_DIR=/

# Database (MySQL)
INGVE_DB_HOST=
INGVE_DB_PORT=3306
INGVE_DB_NAME=
INGVE_DB_USER=
INGVE_DB_PASSWORD=

# SMTP (valgfritt, for kontaktskjema/epost)
INGVE_SMTP_HOST=
INGVE_SMTP_PORT=587
INGVE_SMTP_USER=
INGVE_SMTP_PASSWORD=
INGVE_SMTP_SECURE=true
INGVE_MAIL_FROM=noreply@ingve.com

# SSH/SFTP (kun hvis aktivert i abonnementet)
INGVE_SSH_HOST=
INGVE_SSH_PORT=22
INGVE_SSH_USER=
INGVE_SSH_PASSWORD=

# Deploy/verifisering
INGVE_ENVIRONMENT=production
INGVE_HEALTHCHECK_URL=https://ingve.com
